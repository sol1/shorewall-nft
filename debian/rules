#!/usr/bin/make -f
# Build shorewall-nft by driving the shared installer with the Debian
# path config into the package staging tree.

%:
	dh $@

override_dh_auto_build:
	# Nothing to build; the compiler is pure Python.

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/shorewall-nft \
		packaging/install.sh packaging/shorewallrc.debian

# Ship the service present but disabled and not started. The admin runs
# shorewall migrate or shorewall start when ready.
override_dh_installsystemd:
	dh_installsystemd --no-enable --no-start shorewall.service
	dh_installsystemd --no-enable --no-start shorewall-geoip-update.timer

override_dh_auto_test:
	# The differential suite needs network namespaces; run it out of the
	# package build with tests/run.
