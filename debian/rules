#!/usr/bin/make -f
# Build shorewall-nft by driving the shared installer with the Debian
# path config into the package staging tree.

%:
	dh $@

override_dh_auto_build:
	# Nothing to build; the compiler is pure Python.

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/shorewall-nft \
		packaging/install.sh packaging/shorewallrc.debian

# Ship the service present but disabled and not started. The admin runs
# shorewall migrate or shorewall start when ready.
override_dh_installsystemd:
	# The units are installed into the buildroot by install.sh, not from
	# debian/. Naming them makes older debhelper error when it does not
	# find a matching debian/*.service, so let it auto-process what is
	# present. --no-enable --no-start keeps the package inert.
	dh_installsystemd --no-enable --no-start

override_dh_auto_test:
	# The differential suite needs network namespaces; run it out of the
	# package build with tests/run.

# Compress with gzip, not the builder's default zstd. dpkg on Debian 11
# and other older releases cannot read a zstd-compressed .deb and fails
# the install with "unknown compression for member 'control.tar.zst'".
# The package is tiny pure Python, so the size cost of gzip is nil.
override_dh_builddeb:
	dh_builddeb -- -Zgzip
