#!/bin/sh
# Restore the firewall snapshot that preinst took, if the distro
# shorewall removal cleared the live ruleset. This keeps the box
# protected on its existing rules until `shorewall migrate` performs the
# real iptables-to-nftables handover. We restore only when the live
# ruleset is empty, so we never disturb a firewall that is actually up.
set -e

STASH=${SWNFT_STASH:-/var/lib/shorewall-nft/preswap}
NFT=$(command -v nft 2>/dev/null || echo /usr/sbin/nft)

has_rules() {   # $1 = save command
    command -v "$1" >/dev/null 2>&1 && "$1" 2>/dev/null | grep -q '^-A '
}

nft_loaded() {   # our own nft firewall is up (a shorewall-nft to
                 # shorewall-nft upgrade keeps it loaded in the kernel)
    [ -x "$NFT" ] || return 1
    "$NFT" list table ip shorewall >/dev/null 2>&1 && return 0
    "$NFT" list table ip6 shorewall >/dev/null 2>&1 && return 0
    return 1
}

restore() {   # $1 = restore cmd, $2 = save cmd, $3 = stash file, $4 = label
    f="$STASH/$3"
    [ -s "$f" ] || return 0
    command -v "$1" >/dev/null 2>&1 || return 0
    has_rules "$2" && return 0     # something is already loaded; leave it
    if "$1" < "$f" 2>/dev/null; then
        echo "shorewall-nft: restored the $4 ruleset the shorewall removal" \
             "cleared. It holds until you run 'shorewall migrate'."
    fi
}

if [ "$1" = "configure" ]; then
    restore iptables-restore iptables-save v4 IPv4
    restore ip6tables-restore ip6tables-save v6 IPv6
    # If the box is genuinely unprotected and we had nothing to restore, say
    # so; do not leave it silent. A shorewall-nft to shorewall-nft upgrade
    # keeps its nft firewall loaded, so check that too: without it this warned
    # on every upgrade of a working nft box, whose rules never show in
    # iptables-save (issue #9).
    if [ -d /etc/shorewall ] && ! has_rules iptables-save \
       && ! nft_loaded && [ ! -s "$STASH/v4" ]; then
        echo "shorewall-nft: WARNING: no firewall rules are loaded. The" \
             "previous firewall was cleared and could not be preserved." \
             "Run 'shorewall migrate' now to protect this box." >&2
    fi

    # On upgrade ($2 is the old version; a fresh install has none and stays
    # inert until `shorewall migrate`), bring back any stack that was running
    # before the upgrade, applying the new version's ruleset. This keeps an
    # upgrade from leaving the firewall down if the wider run stopped the
    # service. A failure is a loud warning, not an aborted upgrade.
    if [ -n "$2" ] && [ -e "$STASH/up-v4" ]; then
        echo "shorewall-nft: reloading the running IPv4 firewall on the new version."
        shorewall restart >/dev/null 2>&1 || echo "shorewall-nft: WARNING:" \
            "'shorewall restart' failed; run it by hand to restore the firewall." >&2
    fi
    if [ -n "$2" ] && [ -e "$STASH/up-v6" ]; then
        echo "shorewall-nft: reloading the running IPv6 firewall on the new version."
        shorewall6 restart >/dev/null 2>&1 || echo "shorewall-nft: WARNING:" \
            "'shorewall6 restart' failed; run it by hand to restore the firewall." >&2
    fi

    rm -f "$STASH/v4" "$STASH/v6" "$STASH/up-v4" "$STASH/up-v6"
fi

#DEBHELPER#
exit 0
